# MarketPulse environment configuration (documentation only).
# Copy to .env and fill in real values. NEVER commit .env.

# ---- LLM providers ----
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...            # fallback for cheap calls (GPT-4o-mini)

# ---- PostgreSQL (state, Yelp dataset, audit log) ----
POSTGRES_HOST=localhost
# HOST port published by docker-compose AND the port host-side clients connect
# to. Defaults to 5433 (NOT 5432) to avoid colliding with a native PostgreSQL
# that may already be using 5432 on your machine. The container's internal port
# is always 5432. If 5433 is also taken, change this and DATABASE_URL together.
POSTGRES_PORT=5433
POSTGRES_DB=marketpulse
POSTGRES_USER=marketpulse
# Set this in your real .env (this file is documentation only, .env is gitignored).
# This is the PASSWORD FOR THE DB USER above, created inside the Postgres
# container — it is NOT any host OS user's password. docker-compose fails fast
# if it is unset.
POSTGRES_PASSWORD=change-me
# Connection string for the Python loader (scripts/) and any other host-side
# Python scripts (psycopg / AsyncPostgresSaver).
#   - Replace <PASSWORD> with the SAME value used for POSTGRES_PASSWORD above.
#   - The port is 5433 (the host port from POSTGRES_PORT above), NOT 5432.
#     docker-compose maps the container's internal 5432 to host 5433. Keep this
#     port in sync with POSTGRES_PORT.
#   - The user "marketpulse" matches POSTGRES_USER in docker-compose.yml.
#   - The database name "marketpulse" matches POSTGRES_DB.
DATABASE_URL=postgresql://marketpulse:<PASSWORD>@localhost:5433/marketpulse

# ---- External data APIs ----
FRED_API_KEY=                    # https://fred.stlouisfed.org/docs/api/api_key.html
SEC_EDGAR_USER_AGENT=MarketPulse/0.1 (your-email@example.com)  # SEC requires a UA

# ---- Agent behavior ----
CONFIDENCE_THRESHOLD=0.7         # memos below this route to human review (ADR-005)

# ---- Logging ----
LOG_LEVEL=INFO
