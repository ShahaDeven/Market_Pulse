# MarketPulse environment configuration (documentation only).
# Copy to .env and fill in real values. NEVER commit .env.

# ---- LLM providers ----
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...            # fallback for cheap calls (GPT-4o-mini)

# ---- PostgreSQL (state, Yelp dataset, audit log) ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=marketpulse
POSTGRES_USER=marketpulse
# Set this in your real .env (this file is documentation only, .env is gitignored).
# This is the PASSWORD FOR THE DB USER above, created inside the Postgres
# container — it is NOT any host OS user's password. docker-compose fails fast
# if it is unset.
POSTGRES_PASSWORD=change-me
# Full DSN used by psycopg / AsyncPostgresSaver
DATABASE_URL=postgresql://marketpulse:change-me@localhost:5432/marketpulse

# ---- External data APIs ----
FRED_API_KEY=                    # https://fred.stlouisfed.org/docs/api/api_key.html
SEC_EDGAR_USER_AGENT=MarketPulse/0.1 (your-email@example.com)  # SEC requires a UA

# ---- Agent behavior ----
CONFIDENCE_THRESHOLD=0.7         # memos below this route to human review (ADR-005)

# ---- Logging ----
LOG_LEVEL=INFO
